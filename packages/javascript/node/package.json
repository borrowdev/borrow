{
  "name": "@borrowdev/node",
  "version": "1.2.0",
  "private": false,
  "description": "Borrow.dev: Open-Source Tools for Web Developers",
  "keywords": [
    "borrow.dev",
    "limiter",
    "ratelimiting"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/borrowdev/borrow.git"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/main.mjs",
  "module": "./dist/main.mjs",
  "types": "./dist/main.d.mts",
  "exports": {
    "./limiter/host": {
      "types": "./dist/limiterHost.d.mts",
      "import": "./dist/limiterHost.mjs",
      "default": "./dist/limiterHost.mjs"
    },
    ".": {
      "types": "./dist/main.d.mts",
      "import": "./dist/main.mjs",
      "default": "./dist/main.mjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test"
  },
  "dependencies": {
    "@supabase/supabase-js": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@upstash/redis": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@borrowdev/config": "workspace:*",
    "@borrowdev/node": "workspace:*",
    "@cloudflare/vitest-pool-workers": "catalog:",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "express": "catalog:",
    "fast-check": "catalog:",
    "msw": "catalog:",
    "publint": "catalog:",
    "tslib": "catalog:",
    "type-fest": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  },
  "inlinedDependencies": {
    "type-fest": "4.41.0"
  }
}
