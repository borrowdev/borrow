{
  "extends": "@borrowdev/config/tsconfig.node.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@/*": ["./src/*"]
    },
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "./package.json"],
  "exclude": ["src/**/*.test.*", "src/**/*.spec.*"]
}
