{
  "name": "@borrowdev/limiter",
  "version": "2.0.1",
  "private": false,
  "description": "Self-hostable rate limiting API for serverless environments",
  "keywords": [
    "borrow.dev",
    "limiter",
    "ratelimiting"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/borrowdev/borrow.git"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/main.mjs",
  "module": "./dist/main.mjs",
  "types": "./dist/main.d.mts",
  "exports": {
    "./host": {
      "types": "./dist/host.d.mts",
      "import": "./dist/host.mjs",
      "default": "./dist/host.mjs"
    },
    ".": {
      "types": "./dist/main.d.mts",
      "import": "./dist/main.mjs",
      "default": "./dist/main.mjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test",
    "cf-typegen": "wrangler types --config ./tests/fixtures/environments/cloudflare/wrangler.jsonc ./tests/fixtures/environments/cloudflare/worker-configuration.d.ts",
    "prepare": "vp run cf-typegen"
  },
  "dependencies": {
    "@supabase/supabase-js": "catalog:",
    "@upstash/redis": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@borrowdev/config": "workspace:*",
    "@borrowdev/limiter": "workspace:*",
    "@cloudflare/vitest-pool-workers": "catalog:",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "express": "catalog:",
    "fast-check": "catalog:",
    "msw": "catalog:",
    "publint": "catalog:",
    "tslib": "catalog:",
    "type-fest": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  },
  "inlinedDependencies": {
    "type-fest": "4.41.0"
  }
}
